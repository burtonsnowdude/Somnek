class Items:
    def __init__(self, type_item, nom, hp, hp_max, prix, niveau_requis,
                 degat=None, durabilite=None, refroidissement=None, recuperation=None,
                 vitesse_du_j=None, chance=None, cupidite=None, attirance=None,
                 malchance=None, zone=None, resurrection=None, dernier_tir=None,
                 portee_xp=None, refroidir = None):
        
        
        self.type_item = type_item
        self.nom = nom
        self.hp = hp
        self.hp_max = hp_max
        self.prix = prix
        self.niveau_requis = niveau_requis

        
        self.degat = degat
        self.durabilite = durabilite
        self.refroidissement = refroidissement
        self.recuperation = recuperation
        self.vitesse_du_j = vitesse_du_j
        self.chance = chance
        self.cupidite = cupidite
        self.attirance = attirance
        self.malchance = malchance
        self.resurrection = resurrection
        self.dernier_tir = dernier_tir
        self.portee_xp = portee_xp
        self.refroidir = refroidir
        barre_vie = 100
        
        self.xp = 0  # XP du joueur
        self.argent = 0  # Argent du joueur

    

    def acheter_items(self, solde_j):
        """Achat d'items"""
        if solde_j >= self.prix:
            solde_j -= self.prix
        return solde_j

    def regen_hp(self):
        """Récupération  de PV toutes les secondes"""
        if self.recuperation is None:
            return
        while self.hp < self.hp_max:
            time.sleep(1)
            self.hp += self.recuperation
            if self.hp > self.hp_max:
                self.hp = self.hp_max


    def durabilite(self):
        """Réduit les PV de l'item selon sa durabilité"""
        if self.durabilite is None:
            return
        for _ in range(self.durabilite):
            time.sleep(2)
            self.hp -= 5
    def refroidissement(self, refroidir):
        """Réduit le temps entre attaques"""
        refroidissement = 100
        if self.refroidir  is None:
            return
        else :
            nv_reduction = refroidissement - refroidir
            return nv_reduction
    def vitesse(self, vitesse_j):
        """Augmente la  vitesse du joueur"""
        vitesse_base = 20
        if self.vitesse_j  is None:
            return
        else :
            nv_vitesse_j = vitesse_base + vitesse_j
            return nv_vitesse_j
    def chance(self, chance):
        """Augmente la  chance du joueur"""
        chance_base = 10
        if self.chance is None:
            return
        else :
            nv_chance = chance_base*(1 + chance)
            return nv_chance
        


    def application_refroidissement(self):
        """Appliquer le refroidisemment"""
        maintenant = time.time()
        if self.dernier_tir is None:
            self.dernier_tir = 0
        if maintenant - self.dernier_tir >= self.refroidissement:
            self.dernier_tir = maintenant
            return True
        else:
            return False
    def resurrection(self,barre_vie):  

        """Phénomène de resurrection""" 
        """Prendre la resurection c'est accepter de perdre ses bonus""" 
        if self.resurrection>=1:
            if self.hp == 0 :
                (self.hp + barre_vie)*(1.5)
            else:
                return
        else:
            return 

    
    def cupidite(self, somme):
        """Ajoute un pourcentage à l'argent récolté"""
        if self.cupidite is None:
            return somme
        argent_final = somme * (1 + self.cupidite)
        return argent_final

    def attirance(self, xp, res_x, res_y, jpos_x, jpos_y):
        """Ramasse de l'XP à distance selon l'attirance"""
        if self.attirance is None or self.portee_xp is None:
            return 0
        distance = math.sqrt((jpos_x - res_x)**2 + (jpos_y - res_y)**2)
        while distance <= self.portee_xp:
            self.xp += xp
            return xp
        else:
            return 0
    
    def malchance(self,dg_ennemis, frequence):
        """Applique les effets de la malchance'"""
        if self.malchance is None : 
            return
        dg_supp = dg_ennemis + self.malchance
        nv_frequence = frequence + self.malchance
        return dg_supp, nv_frequence
