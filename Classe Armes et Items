import time
import math

class Items:
    def __init__(self, type_item, nom, hp, hp_max, prix, niveau_requis,
                 degat=None, durabilite=None, refroidissement=None, recuperation=None,
                 vitesse_du_j=None, chance=None, cupidite=None, attirance=None,
                 malchance=None, zone=None, resurrection=None, dernier_tir=None,
                 portee_xp=None):
        
        
        self.type_item = type_item
        self.nom = nom
        self.hp = hp
        self.hp_max = hp_max
        self.prix = prix
        self.niveau_requis = niveau_requis

        
        self.degat = degat
        self.durabilite = durabilite
        self.refroidissement = refroidissement
        self.recuperation = recuperation
        self.vitesse_du_j = vitesse_du_j
        self.chance = chance
        self.cupidite = cupidite
        self.attirance = attirance
        self.malchance = malchance
        self.zone = zone
        self.resurrection = resurrection
        self.dernier_tir = dernier_tir
        self.portee_xp = portee_xp

        # Etat interne
        self.xp = 0  # XP du joueur
        self.argent = 0  # Argent du joueur

    

    def buy_items(self, solde_j):
        if solde_j >= self.prix:
            solde_j -= self.prix
        return solde_j

    def regen_hp(self):
        """Récupération progressive de PV toutes les secondes"""
        if self.recuperation is None:
            return
        while self.hp < self.hp_max:
            time.sleep(1)
            self.hp += self.recuperation
            if self.hp > self.hp_max:
                self.hp = self.hp_max


    def appliquer_durabilite(self):
        """Réduit les PV de l'item selon sa durabilité"""
        if self.durabilite is None:
            return
        for _ in range(self.durabilite):
            time.sleep(2)
            self.hp -= 5

    def appliquer_cooldown(self):
        """Réduit le temps entre attaques si l'item est utilisé comme arme"""
        if self.refroidissement is None or self.degat is None:
            return False
        maintenant = time.time()
        if self.dernier_tir is None:
            self.dernier_tir = 0
        if maintenant - self.dernier_tir >= self.refroidissement:
            self.dernier_tir = maintenant
            return True
        else:
            return False

    def appliquer_cupidite(self, somme):
        """Ajoute un pourcentage de cupidité à la somme récoltée"""
        if self.cupidite is None:
            return somme
        argent_final = somme * (1 + self.cupidite)
        return argent_final

    def appliquer_attirance(self, xp, source_x, source_y, joueur_x, joueur_y):
        """Ramasse de l'XP à distance selon portee_xp"""
        if self.attirance is None or self.portee_xp is None:
            return 0
        distance = math.sqrt((joueur_x - source_x)**2 + (joueur_y - source_y)**2)
        if distance <= self.portee_xp:
            self.xp += xp
            return xp
        else:
            return 0
